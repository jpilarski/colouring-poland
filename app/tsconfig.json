{
    "compilerOptions": {
        "outDir": "./build",
        "rootDir": "./src",
        "allowJs": true,
        "module": "es2020",
        "target": "es2017",
        "jsx": "react",
        "lib": [
            "es6",
            "es2015",
            "es2017",
            "dom"
        ],
        "moduleResolution": "node",
        "ignoreDeprecations": "6.0",
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "noImplicitAny": false
    },
    "files": [
        "./src/index.ts",
        "./src/client.tsx"
    ],
    "include": [
        "./src/**/*.test.*",
        "./src/**/*.spec.*"
    ]
}